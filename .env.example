# SQLite database path. The file is created automatically on first migration.
# Local dev: relative to the prisma/ folder.
# In Docker, docker-compose.yml overrides this with an absolute path
# (file:/app/data/gate.db) so the DB lands in the mounted volume and persists
# across container restarts.
DATABASE_URL="file:./data/gate.db"

# The port THIS gate listens on, on the host (the VPS).
# Run multiple gates on one server by giving each a different port:
# gate A -> 3000, gate B -> 3001, gate C -> 3002, etc.
# Your reverse proxy for each domain forwards to that gate's HOST_PORT.
HOST_PORT=3000

# SoundCloud app credentials. Register an app at https://soundcloud.com/you/apps
# and set the redirect URI to EXACTLY what you put below. PKCE is handled by the
# app; leave "Use PKCE" enabled if the form shows it. Create ONE app per
# SoundCloud account — do not reuse the same Client ID across multiple gates
# or domains.
SC_CLIENT_ID=""
SC_CLIENT_SECRET=""
SC_REDIRECT_URI="https://your-domain.com/callback"

# Artist profile URN. Must start with soundcloud:users:.
# Resolve it with the helper script: npx tsx scripts/resolve-urn.ts
SC_ARTIST_URN=""

# Optional fallback admin password hash. The first-run wizard stores the
# password in the database, so this is only needed for manual/advanced setups.
# Generate with: node -e "console.log(require('bcryptjs').hashSync('your-password', 12))"
# IMPORTANT: if you paste the hash directly into this file, escape every $
# as $$ because Docker Compose / some shells treat $ as a variable.
ADMIN_PASSWORD_HASH=""

# 32-byte hex secret for admin session cookies. Generate with:
# node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=""

# 32-byte hex secret for signed download tokens. Generate the same way as
# SESSION_SECRET. Keep it different from SESSION_SECRET.
DOWNLOAD_TOKEN_SECRET=""

# Local directory where uploaded audio files are stored. Must be writable and
# persistent across restarts. In Docker this is mounted as a volume.
STORAGE_DIR="./storage/downloads"
